{
  "rules": {
    ".read": true,

    "predictions": {
      "$mid": {
        ".write": "root.child('meta/ko/' + $mid).exists() && now < root.child('meta/ko/' + $mid).val()"
      }
    },

    "scores": {
      ".write": true
    },

    "koTeams": {
      ".write": true
    },

    "finalPicks": {
      ".write": true
    },

    "meta": {
      ".write": false
    }
  }
}
